# Runtime
NODE_ENV=development
PORT=3000
PUBLIC_BASE_URL=http://localhost:3000
TEST_MODE=true
MOCK_BOARD_MODE=true
MOCK_BOARD_DATA_PATH=./mock-data.local.json
SCHEDULER_SECRET=change-me-for-deployed-cron
MAX_SMS_PER_SCHEDULER_RUN=25
MONDAY_SMS_LOG_MAX_CHARS=12000

# Monday.com
MONDAY_API_TOKEN=
MONDAY_BOARD_ID=
MONDAY_API_VERSION=2024-10

# Monday column IDs. Update these after creating the board columns.
MONDAY_COL_CUSTOMER_NAME=customer_name
MONDAY_COL_PHONE=phone
MONDAY_COL_EMAIL=email
MONDAY_COL_STAGE=stage
MONDAY_COL_STATUS=status
MONDAY_COL_AUTOMATION_PAUSED=automation_paused
MONDAY_COL_STOP_AUTOMATION=stop_automation
MONDAY_COL_LAST_CUSTOMER_REPLY_AT=last_customer_reply_at
MONDAY_COL_LAST_OUTBOUND_SMS_AT=last_outbound_sms_at
MONDAY_COL_LAST_OUTBOUND_TEMPLATE=last_outbound_template
MONDAY_COL_NEW_LEAD_CONFIRMED_AT=new_lead_confirmed_at
MONDAY_COL_QUOTE_SENT_AT=quote_sent_at
MONDAY_COL_QUOTE_FOLLOWUP_STEP=quote_followup_step
MONDAY_COL_IN_PROGRESS_LAST_UPDATE_AT=in_progress_last_update_at
MONDAY_COL_APPOINTMENT_AT=appointment_at
MONDAY_COL_APPOINTMENT_REMINDER_24H_AT=appointment_reminder_24h_at
MONDAY_COL_APPOINTMENT_REMINDER_2H_AT=appointment_reminder_2h_at
MONDAY_COL_INSTALL_COMPLETED_AT=install_completed_at
MONDAY_COL_AFTER_INSTALL_THANK_YOU_AT=after_install_thank_you_at
MONDAY_COL_REVIEW_REQUEST_SENT_AT=review_request_sent_at
MONDAY_COL_SMS_LOG=sms_log

# SMS provider: twilio, freedomvoice, mock
SMS_PROVIDER=mock
FROM_SMS_NUMBER=
INTERNAL_NOTIFICATION_NUMBER=

# Twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_MESSAGING_SERVICE_SID=
TWILIO_VALIDATE_WEBHOOKS=true

# FreedomVoice placeholder
FREEDOMVOICE_API_KEY=
FREEDOMVOICE_API_BASE_URL=

# Business links
GOOGLE_REVIEW_URL=https://g.page/r/your-review-link
BUXTON_OFFICE_PHONE=
