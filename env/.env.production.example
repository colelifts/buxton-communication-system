NODE_ENV=production
PUBLIC_BASE_URL=https://YOUR-DOMAIN
TEST_MODE=false
MOCK_BOARD_MODE=false
SMS_PROVIDER=twilio
SCHEDULER_SECRET=REPLACE_WITH_LONG_RANDOM_VALUE
MAX_SMS_PER_SCHEDULER_RUN=25
MONDAY_SMS_LOG_MAX_CHARS=12000
MONDAY_API_TOKEN=SET_IN_HOST_SECRETS
MONDAY_BOARD_ID=SET_IN_HOST_SECRETS
MONDAY_API_VERSION=2024-10
TWILIO_ACCOUNT_SID=SET_IN_HOST_SECRETS
TWILIO_AUTH_TOKEN=SET_IN_HOST_SECRETS
TWILIO_MESSAGING_SERVICE_SID=SET_IN_HOST_SECRETS
TWILIO_VALIDATE_WEBHOOKS=true
INTERNAL_NOTIFICATION_NUMBER=+1...
GOOGLE_REVIEW_URL=https://g.page/r/your-review-link
EMAIL_ENABLED=false
EMAIL_PROVIDER=mock
EMAIL_FROM_ADDRESS=hello@yourdomain.com
EMAIL_FROM_NAME=Buxton Blinds
INTERNAL_NOTIFICATION_EMAIL=team@yourdomain.com
RESEND_API_KEY=SET_IN_HOST_SECRETS
BREVO_API_KEY=SET_IN_HOST_SECRETS
